    private func loadExercises() {
        isLoading = true
        let formatter = DateFormatter()
        formatter.dateFormat = "yyyy-MM-dd"
        let dateStr = formatter.string(from: selectedDate)
        
        Task {
            do {
                // 1. Apelăm getClientExercises exact cum faci pe Android
